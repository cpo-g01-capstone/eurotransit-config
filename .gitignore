# Never commit these — seal with kubeseal first
.env
.env.*
*-not-to-be-versioned.yaml
*-not-to-be-versioned.json

# Plaintext secrets under any secrets/ dir — commit only the sealed output.
# Convention: secrets/*.yaml is the local plaintext (gitignored); the sealed
# manifest MUST be named secrets/*.sealed.yaml (kept, negated below).
**/secrets/*.yaml
!**/secrets/*.sealed.yaml

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx

# Helm chart lock (regenerated by helm dependency update)
# Keep Chart.lock in git — it pins exact dependency versions
# charts/        ← keep charts/ dir out only if you vendor elsewhere

# Local tool state
.DS_Store
.idea/
*.iml

# Personal/local agent overrides — not shared
.agent/local/
.claude.local.md
.agents/*
*.local.md
*.local.png
*.local.pdf